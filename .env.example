# Contact SoftLedger support to register your application. You'll receive the
# authorization domain, a client id, and a client secret — give them your
# redirect URIs (both localhost URIs below for these demos).
SOFTLEDGER_AUTH_DOMAIN=https://...   # provided by SoftLedger
PARTNER_APP_CLIENT_ID=client_...
PARTNER_APP_CLIENT_SECRET=...
SIGN_IN_REDIRECT_URI=http://localhost:4001/auth/callback
ACCOUNT_LINK_REDIRECT_URI=http://localhost:4002/oauth/callback

# SoftLedger API base (the granted access token is sent as Bearer auth)
SOFTLEDGER_API_URL=https://api.softledger.com

# Optional
# SIGN_IN_PORT=4001
# ACCOUNT_LINK_PORT=4002
# SESSION_SECRET=...   # set a real value for anything deployed
