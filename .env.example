# WorkOS Connect application for your SoftLedger environment.
# The AuthKit domain and the client id must belong to the same environment;
# register both redirect URIs (4001 + 4002) on the application.
WORKOS_AUTHKIT_DOMAIN=https://your-env-slug.authkit.app
PARTNER_APP_CLIENT_ID=client_...
PARTNER_APP_CLIENT_SECRET=...
PARTNER_APP_REDIRECT_URI=http://localhost:4001/auth/callback
LOGIN_APP_REDIRECT_URI=http://localhost:4002/oauth/callback

# SoftLedger API base (the granted access token is sent as Bearer auth)
SOFTLEDGER_API_URL=https://api.softledger.com

# Optional
# PARTNER_APP_PORT=4001
# LOGIN_APP_PORT=4002
# SESSION_SECRET=...   # set a real value for anything deployed
